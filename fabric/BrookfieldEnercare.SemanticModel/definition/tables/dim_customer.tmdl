/// Unified customer profile combining account details, active contracts, equipment count, and lifetime billing value. Primary analytical surface for customer success and retention teams. One row per customer.
table dim_customer
	lineageTag: 4ce75090-884b-444b-ba5d-01ef91eea191
	sourceLineageTag: [dbo].[dim_customer]

	/// Surrogate key for the customer record
	column CustomerKey
		dataType: int64
		formatString: 0
		lineageTag: 01aec572-4d94-4f6a-ac4c-ccacd3746702
		sourceLineageTag: CustomerKey
		summarizeBy: count
		sourceColumn: CustomerKey

		annotation SummarizationSetBy = Automatic

	/// External-facing identifier used in all customer communications
	column AccountNumber
		dataType: string
		lineageTag: 6cefd132-2f79-4810-a99b-5feb1add9554
		sourceLineageTag: AccountNumber
		summarizeBy: none
		sourceColumn: AccountNumber

		annotation SummarizationSetBy = Automatic

	/// Base account key used to normalize optional "-SVC" suffix variants.
	column NormalizedAccountKey = UPPER(SUBSTITUTE([AccountNumber], "-SVC", ""))
